# Agentic Navigator Backend Configuration
# Copy to .env and edit as needed

# Application Mode: "mock" (default, no API keys needed) or "live" (real APIs)
APP_MODE=mock
APP_PORT=8000
APP_HOST=0.0.0.0

# HERE APIs (only needed for live mode)
HERE_API_KEY=
HERE_BASE_URL=https://router.hereapi.com

# Weather API (only needed for live mode)
WEATHER_API_KEY=
WEATHER_API_URL=https://api.open-meteo.com

# Logging
LOG_LEVEL=INFO

# Timeouts (seconds)
REQUEST_TIMEOUT_SECONDS=10
AGENT_TIMEOUT_SECONDS=5

# Mock configuration
MOCK_SCENARIO=default

# Trace retention
TRACE_RETENTION_COUNT=100

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
