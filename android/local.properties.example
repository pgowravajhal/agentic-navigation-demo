# HERE SDK credentials — DO NOT commit the real local.properties to git!
# Copy this file to local.properties and fill in your credentials.
#
# Get credentials from https://platform.here.com/
# Create a new project → REST → Generate App

HERE_ACCESS_KEY_ID=your-access-key-id-here
HERE_ACCESS_KEY_SECRET=your-access-key-secret-here

# Android SDK (auto-filled by Android Studio)
# sdk.dir=/path/to/android/sdk
